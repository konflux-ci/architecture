#!/bin/bash

# lint-agents-md - Validate line counts in AGENTS.md files
#
# Checks that line counts listed in architecture/AGENTS.md and
# ADR/AGENTS.md match actual files, and that all documents are listed.
#
# Exit codes:
#   0 - All line counts are accurate
#   1 - Mismatched or missing line counts found

set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m'

error() { echo -e "${RED}ERROR:${NC} $1" >&2; }
success() { echo -e "${GREEN}SUCCESS:${NC} $1"; }
info() { echo -e "${BLUE}INFO:${NC} $1"; }
warning() { echo -e "${YELLOW}WARNING:${NC} $1"; }

ARCH_AGENTS="architecture/AGENTS.md"
ADR_AGENTS="ADR/AGENTS.md"

errors=0
checked=0

# Verify root AGENTS.md is a symlink to CLAUDE.md
if [[ -L "AGENTS.md" ]]; then
    target=$(readlink "AGENTS.md")
    if [[ "$target" != "CLAUDE.md" ]]; then
        error "AGENTS.md symlink points to '$target', expected 'CLAUDE.md'"
        ((errors++)) || true
    fi
elif [[ -f "AGENTS.md" ]]; then
    error "AGENTS.md should be a symlink to CLAUDE.md, not a regular file"
    ((errors++)) || true
fi

# --- Validate architecture/AGENTS.md ---
info "Validating $ARCH_AGENTS..."
echo "========================================"

if [[ ! -f "$ARCH_AGENTS" ]]; then
    error "$ARCH_AGENTS not found"
    ((errors++)) || true
else
    while IFS= read -r line; do
        if [[ $line =~ ^\|[[:space:]]*([a-zA-Z_/.-]+\.md)[[:space:]]*\|[[:space:]]*([0-9]+)[[:space:]]*\| ]]; then
            file="architecture/${BASH_REMATCH[1]}"
            claimed="${BASH_REMATCH[2]}"
            if [[ ! -f "$file" ]]; then
                error "File not found: $file (listed with $claimed lines)"
                ((errors++)) || true
                ((checked++)) || true
                continue
            fi
            actual=$(wc -l < "$file")
            if [[ "$actual" -ne "$claimed" ]]; then
                error "$file: listed as $claimed lines, actual $actual lines"
                ((errors++)) || true
            fi
            ((checked++)) || true
        fi
    done < "$ARCH_AGENTS"

    # Check completeness
    for file in architecture/core/*.md architecture/add-ons/*.md architecture/index.md; do
        relpath="${file#architecture/}"
        if [[ -f "$file" ]] && ! grep -q "$relpath" "$ARCH_AGENTS"; then
            warning "File not listed in $ARCH_AGENTS: $file"
            ((errors++)) || true
        fi
    done
fi

# --- Validate ADR/AGENTS.md ---
info "Validating $ADR_AGENTS..."
echo "========================================"

if [[ ! -f "$ADR_AGENTS" ]]; then
    error "$ADR_AGENTS not found"
    ((errors++)) || true
else
    while IFS= read -r line; do
        if [[ $line =~ ^\|[[:space:]]*([0-9]{4})[[:space:]]*\|[[:space:]]*[A-Za-z]+[[:space:]]*\|[[:space:]]*([0-9]+)[[:space:]]*\| ]]; then
            adr_num="${BASH_REMATCH[1]}"
            claimed="${BASH_REMATCH[2]}"
            adr_file=$(find ADR/ -maxdepth 1 -name "${adr_num}-*.md" -type f 2>/dev/null | head -1)
            if [[ -z "$adr_file" ]]; then
                error "ADR file not found for number: $adr_num (listed with $claimed lines)"
                ((errors++)) || true
                ((checked++)) || true
                continue
            fi
            actual=$(wc -l < "$adr_file")
            if [[ "$actual" -ne "$claimed" ]]; then
                error "$adr_file: listed as $claimed lines, actual $actual lines"
                ((errors++)) || true
            fi
            ((checked++)) || true
        fi
    done < "$ADR_AGENTS"

    # Check completeness
    while IFS= read -r -d '' adr_file; do
        adr_num=$(basename "$adr_file" | cut -c1-4)
        if ! grep -qE "^\| ${adr_num} " "$ADR_AGENTS"; then
            warning "ADR not listed in $ADR_AGENTS: $(basename "$adr_file")"
            ((errors++)) || true
        fi
    done < <(find ADR/ -name "[0-9]*.md" -type f -print0 | sort -z)
fi

echo "========================================"

if [[ $errors -eq 0 ]]; then
    success "All $checked entries in AGENTS.md files are accurate"
    exit 0
else
    error "$errors issue(s) found — run 'hack/util/generate-agents-md' to regenerate"
    exit 1
fi
