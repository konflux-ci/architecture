#!/bin/bash

# lint-agents-md - Validate line counts in AGENTS.md
#
# This script checks that the line counts listed in AGENTS.md match
# the actual line counts of the referenced files. This ensures the
# progressive disclosure metadata stays accurate as documents change.
#
# Exit codes:
#   0 - All line counts are accurate
#   1 - Mismatched or missing line counts found

set -euo pipefail

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
NC='\033[0m' # No Color

# Function to print error messages
error() {
    echo -e "${RED}ERROR:${NC} $1" >&2
}

# Function to print success messages
success() {
    echo -e "${GREEN}SUCCESS:${NC} $1"
}

# Function to print info messages
info() {
    echo -e "${BLUE}INFO:${NC} $1"
}

# Function to print warning messages
warning() {
    echo -e "${YELLOW}WARNING:${NC} $1"
}

AGENTS_FILE="AGENTS.md"

if [[ ! -f "$AGENTS_FILE" ]]; then
    error "AGENTS.md not found"
    exit 1
fi

errors=0
checked=0

info "Validating line counts in AGENTS.md..."
echo "========================================"

# Check file-path entries (tables with path in first column)
# Matches lines like: | architecture/core/build-service.md | 285 | ...
while IFS= read -r line; do
    # Extract file path and claimed line count from table rows
    # Pattern: | <path>.md | <number> | ...
    if [[ $line =~ ^\|[[:space:]]*([a-zA-Z_/.-]+\.md)[[:space:]]*\|[[:space:]]*([0-9]+)[[:space:]]*\| ]]; then
        file="${BASH_REMATCH[1]}"
        claimed="${BASH_REMATCH[2]}"

        if [[ ! -f "$file" ]]; then
            error "File not found: $file (listed with $claimed lines)"
            ((errors++)) || true
            ((checked++)) || true
            continue
        fi

        actual=$(wc -l < "$file")
        if [[ "$actual" -ne "$claimed" ]]; then
            error "$file: listed as $claimed lines, actual $actual lines"
            ((errors++)) || true
        fi
        ((checked++)) || true
    fi
done < "$AGENTS_FILE"

# Check ADR entries (tables with ADR number in first column)
# Matches lines like: | 0001 | Rp | 58 | ...
while IFS= read -r line; do
    if [[ $line =~ ^\|[[:space:]]*([0-9]{4})[[:space:]]*\|[[:space:]]*[A-Za-z]+[[:space:]]*\|[[:space:]]*([0-9]+)[[:space:]]*\| ]]; then
        adr_num="${BASH_REMATCH[1]}"
        claimed="${BASH_REMATCH[2]}"

        # Find the ADR file matching this number
        adr_file=$(find ADR/ -maxdepth 1 -name "${adr_num}-*.md" -type f 2>/dev/null | head -1)

        if [[ -z "$adr_file" ]]; then
            error "ADR file not found for number: $adr_num (listed with $claimed lines)"
            ((errors++)) || true
            ((checked++)) || true
            continue
        fi

        actual=$(wc -l < "$adr_file")
        if [[ "$actual" -ne "$claimed" ]]; then
            error "$adr_file: listed as $claimed lines, actual $actual lines"
            ((errors++)) || true
        fi
        ((checked++)) || true
    fi
done < "$AGENTS_FILE"

# Check that all architecture docs are listed in AGENTS.md
for file in architecture/core/*.md architecture/add-ons/*.md architecture/index.md; do
    if [[ -f "$file" ]] && ! grep -q "$file" "$AGENTS_FILE"; then
        warning "File not listed in AGENTS.md: $file"
        ((errors++)) || true
    fi
done

# Check that all ADR files are listed
while IFS= read -r -d '' adr_file; do
    adr_num=$(basename "$adr_file" | cut -c1-4)
    if ! grep -qE "^\| ${adr_num} " "$AGENTS_FILE"; then
        warning "ADR not listed in AGENTS.md: $(basename "$adr_file")"
        ((errors++)) || true
    fi
done < <(find ADR/ -name "[0-9]*.md" -type f -print0 | sort -z)

echo "========================================"

if [[ $errors -eq 0 ]]; then
    success "All $checked entries in AGENTS.md are accurate"
    exit 0
else
    error "$errors issue(s) found in AGENTS.md — run 'hack/util/generate-agents-md' to regenerate"
    exit 1
fi
